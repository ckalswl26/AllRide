DEBUG=True

# TMAP Open API 앱 키: 서버에서 자동차 경로 안내 API를 호출할 때 사용합니다.
TMAP_API_KEY=YOUR_TMAP_APP_KEY

# Kakao Maps JavaScript SDK 키: 브라우저에서 실제 카카오맵을 렌더링합니다.
KAKAO_JS_KEY=YOUR_KAKAO_JAVASCRIPT_KEY

# 선택: 향후 장소 검색·지오코딩 서버 연동용 REST API 키
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
# 이전 변수명도 호환됩니다.
KAKAO_API_KEY=

# 선택: 사고 다발 구간 공공데이터 연동
PUBLIC_DATA_API_KEY=YOUR_PUBLIC_DATA_API_KEY
